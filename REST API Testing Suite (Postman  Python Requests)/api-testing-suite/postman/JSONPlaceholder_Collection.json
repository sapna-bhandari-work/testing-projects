        {
          "name": "GET Posts Filtered ?userId=1 — all items have userId=1",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('user_id', '1');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response is a non-empty array', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.be.an('array').with.length.above(0);",
                  "});",
                  "",
                  "pm.test('Every item has userId equal to 1', function () {",
                  "    var data = pm.response.json();",
                  "    data.forEach(function (post) {",
                  "        pm.expect(post.userId).to.eql(1,",
                  "            'Post id=' + post.id + ' has unexpected userId=' + post.userId);",
                  "    });",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/posts?userId={{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts"],
              "query": [
                { "key": "userId", "value": "{{user_id}}" }
              ]
            },
            "description": "Retrieves posts filtered by userId=1. Every returned item must have userId=1."
          }
        },
        {
          "name": "GET User /users/1 — status 200",
          "event": [
            {
              "listen": "prerequest",
