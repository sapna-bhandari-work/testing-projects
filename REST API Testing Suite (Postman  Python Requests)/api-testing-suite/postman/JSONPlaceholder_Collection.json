    {
      "name": "POST Tests",
      "description": "Tests for POST /posts: valid payload, empty body, and auto-generated id.",
      "item": [
        {
          "name": "POST /posts — valid payload, status 201, echoed fields",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Set the request body variables for this POST request.",
                  "pm.environment.set('post_title', 'Test Post Title');",
                  "pm.environment.set('post_body', 'This is the body content of the automated test post.');",
                  "pm.environment.set('post_userId', 1);"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 201 Created', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "pm.test('Response echoes submitted title', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.title).to.eql('Test Post Title');",
                  "});",
                  "",
                  "pm.test('Response echoes submitted body', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.body).to.eql('This is the body content of the automated test post.');",
                  "});",
                  "",
                  "pm.test('Response echoes submitted userId', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.userId).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Response time is below 2000 ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json; charset=UTF-8" },
              { "key": "Accept", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"title\": \"Test Post Title\",\n    \"body\": \"This is the body content of the automated test post.\",\n    \"userId\": 1\n}",
              "options": {
                "raw": { "language": "json" }
              }
            },
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            },
            "description": "Creates a new post with a valid payload. Validates status=201 and all submitted fields are echoed back."
          }
