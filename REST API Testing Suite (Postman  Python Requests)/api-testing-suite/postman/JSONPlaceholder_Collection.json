          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Retrieves user with id=1. Validates status=200 and all top-level required fields are present."
          }
        },
        {
          "name": "GET User /users/1 — schema validation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('user_id', '1');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var userSchema = {",
                  "    '$schema': 'http://json-schema.org/draft-07/schema#',",
                  "    'title': 'User',",
                  "    'type': 'object',",
                  "    'required': ['id','name','username','email','address','phone','website','company'],",
                  "    'properties': {",
                  "        'id':       { 'type': 'integer', 'minimum': 1 },",
                  "        'name':     { 'type': 'string' },",
                  "        'username': { 'type': 'string' },",
                  "        'email':    { 'type': 'string' },",
                  "        'address': {",
                  "            'type': 'object',",
                  "            'required': ['street','suite','city','zipcode','geo'],",
                  "            'properties': {",
                  "                'street':  { 'type': 'string' },",
                  "                'suite':   { 'type': 'string' },",
                  "                'city':    { 'type': 'string' },",
                  "                'zipcode': { 'type': 'string' },",
                  "                'geo': {",
                  "                    'type': 'object',",
                  "                    'required': ['lat','lng'],",
                  "                    'properties': {",
                  "                        'lat': { 'type': 'string' },",
                  "                        'lng': { 'type': 'string' }",
                  "                    }",
                  "                }",
                  "            }",
                  "        },",
                  "        'phone':   { 'type': 'string' },",
                  "        'website': { 'type': 'string' },",
                  "        'company': {",
                  "            'type': 'object',",
                  "            'required': ['name','catchPhrase','bs'],",
                  "            'properties': {",
                  "                'name':         { 'type': 'string' },",
                  "                'catchPhrase':  { 'type': 'string' },",
                  "                'bs':           { 'type': 'string' }",
                  "            }",
                  "        }",
                  "    }",
                  "};",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response body matches user_schema (Draft-07)', function () {",
                  "    pm.response.to.have.jsonSchema(userSchema);",
                  "});",
                  "",
                  "pm.test('Address contains geo with lat and lng', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.address.geo).to.have.property('lat');",
                  "    pm.expect(data.address.geo).to.have.property('lng');",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/users/{{user_id}}",
              "host": ["{{base_url}}"],
              "path": ["users", "{{user_id}}"]
            },
            "description": "Validates GET /users/1 response body against the inline user schema (mirrors user_schema.json Draft-07 definition)."
          }
        }
