    "name": "JSONPlaceholder API Test Suite",
    "description": "Comprehensive REST API test collection for the JSONPlaceholder public mock API (https://jsonplaceholder.typicode.com).\n\nCovers GET, POST, PUT, and DELETE operations with assertions for:\n- HTTP status codes\n- Response body field presence and values\n- JSON Schema structure validation\n- Response time SLA (< 2 000 ms)\n\nParallel implementation: python_suite/ using PyTest + Requests.\n\nImport this collection together with JSONPlaceholder_Environment.json before running.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "GET Tests",
      "description": "Tests for all GET endpoints: /posts collection, single post, filtered posts, 404 handling, and /users.",
      "item": [
        {
          "name": "GET All Posts — status 200, is list, non-empty",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "// Ensure the base_url variable is set before the request fires.",
                  "if (!pm.environment.get('base_url')) {",
                  "    pm.environment.set('base_url', 'https://jsonplaceholder.typicode.com');",
                  "}"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response body is an array', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.be.an('array');",
                  "});",
                  "",
                  "pm.test('Array is not empty (length > 0)', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.length).to.be.above(0);",
                  "});",
                  "",
                  "pm.test('Response time is below 2000 ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/posts",
              "host": ["{{base_url}}"],
              "path": ["posts"]
            },
            "description": "Retrieves the full collection of posts. Validates status=200, response is a non-empty array, and response time SLA."
          }
        },
        {
          "name": "GET Single Post /posts/1 — required keys",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('post_id', '1');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response contains required keys: id, title, body, userId', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data).to.have.property('id');",
                  "    pm.expect(data).to.have.property('title');",
                  "    pm.expect(data).to.have.property('body');",
                  "    pm.expect(data).to.have.property('userId');",
                  "});",
                  "",
                  "pm.test('id field value equals 1', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.id).to.eql(1);",
                  "});",
                  "",
                  "pm.test('Response time is below 2000 ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(2000);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/posts/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{post_id}}"]
            },
            "description": "Retrieves post with id=1. Validates status=200, presence of all required fields, and id value."
          }
        },
        {
          "name": "GET Single Post /posts/1 — schema validation",
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "pm.environment.set('post_id', '1');"
                ],
                "type": "text/javascript"
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var postSchema = {",
                  "    '$schema': 'http://json-schema.org/draft-07/schema#',",
                  "    'title': 'Post',",
                  "    'type': 'object',",
                  "    'required': ['userId', 'id', 'title', 'body'],",
                  "    'additionalProperties': false,",
                  "    'properties': {",
                  "        'userId': { 'type': 'integer', 'minimum': 1 },",
                  "        'id':     { 'type': 'integer', 'minimum': 1 },",
                  "        'title':  { 'type': 'string', 'minLength': 1 },",
                  "        'body':   { 'type': 'string', 'minLength': 1 }",
                  "    }",
                  "};",
                  "",
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response body matches post_schema (Draft-07)', function () {",
                  "    pm.response.to.have.jsonSchema(postSchema);",
                  "});",
                  "",
                  "pm.test('userId is an integer >= 1', function () {",
                  "    var data = pm.response.json();",
                  "    pm.expect(data.userId).to.be.a('number').and.to.be.above(0);",
                  "});"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [
              { "key": "Accept", "value": "application/json" }
            ],
            "url": {
              "raw": "{{base_url}}/posts/{{post_id}}",
              "host": ["{{base_url}}"],
              "path": ["posts", "{{post_id}}"]
            },
            "description": "Validates the response body of GET /posts/1 against the inline post schema (mirrors post_schema.json Draft-07 definition)."
          }
        },
